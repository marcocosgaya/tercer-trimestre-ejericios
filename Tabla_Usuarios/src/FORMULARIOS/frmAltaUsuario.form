                </properties>
              </component>
            </children>
          </grid>
          <grid id="f08ae" layout-manager="GridBagLayout">
            <constraints border-constraint="Center"/>
            <properties/>
            <border type="none"/>
            <children>
              <component id="138b6" class="javax.swing.JLabel" binding="lblUsuario">
                <constraints>
                  <grid row="1" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="0" anchor="8" fill="0" indent="0" use-parent-layout="false"/>
                  <gridbag weightx="0.0" weighty="0.0"/>
                </constraints>
                <properties>
                  <text value="Usuario"/>
                </properties>
              </component>
              <component id="8db50" class="javax.swing.JLabel" binding="lblPassword">
