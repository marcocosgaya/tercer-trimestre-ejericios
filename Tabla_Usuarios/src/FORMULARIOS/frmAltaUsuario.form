    <properties/>
    <border type="none"/>
    <children>
      <grid id="b4aa2" layout-manager="BorderLayout" hgap="0" vgap="0">
        <constraints border-constraint="Center"/>
        <properties/>
        <border type="none"/>
        <children>
          <grid id="795af" layout-manager="FlowLayout" hgap="5" vgap="5" flow-align="1">
            <constraints border-constraint="South"/>
            <properties/>
            <border type="none"/>
            <children>
              <component id="d6409" class="javax.swing.JLabel">
                <constraints/>
                <properties>
                  <enabled value="false"/>
                  <text value=""/>
                </properties>
              </component>
              <component id="c256" class="javax.swing.JLabel" binding="label">
