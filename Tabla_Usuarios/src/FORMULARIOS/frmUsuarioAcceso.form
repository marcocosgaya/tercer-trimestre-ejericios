<?xml version="1.0" encoding="UTF-8"?>
<form xmlns="http://www.intellij.com/uidesigner/form/" version="1" bind-to-class="FORMULARIOS.frmUsuarioAcceso">
  <grid id="27dc6" binding="panel1" default-binding="true" layout-manager="BorderLayout" hgap="0" vgap="0">
    <constraints>
      <xy x="20" y="20" width="500" height="400"/>
    </constraints>
    <properties/>
    <border type="none"/>
    <children>
      <grid id="a3ad" layout-manager="FlowLayout" hgap="5" vgap="5" flow-align="1">
        <constraints border-constraint="South"/>
        <properties/>
        <border type="none"/>
        <children>
          <component id="79f99" class="javax.swing.JLabel" binding="lblAcceso">
            <constraints/>
            <properties>
              <enabled value="false"/>
              <text value=""/>
            </properties>
          </component>
          <component id="98f49" class="javax.swing.JButton" binding="btnAlta">
            <constraints/>
            <properties>
              <text value="Alta"/>
            </properties>
          </component>
          <component id="e9d32" class="javax.swing.JButton" binding="btnEntrar">
            <constraints/>
            <properties>
              <text value="Entrar"/>
            </properties>
          </component>
          <component id="42533" class="javax.swing.JButton" binding="btnSalir">
            <constraints/>
            <properties>
              <text value="Salir"/>
            </properties>
          </component>
        </children>
      </grid>
      <grid id="fa626" layout-manager="FlowLayout" hgap="5" vgap="5" flow-align="1">
        <constraints border-constraint="North"/>
        <properties/>
        <border type="none"/>
        <children>
          <component id="70060" class="javax.swing.JLabel" binding="lbl">
            <constraints/>
            <properties>
              <text value="ACCESO USUARIOS"/>
            </properties>
          </component>
        </children>
      </grid>
      <grid id="cfaff" layout-manager="GridBagLayout">
        <constraints border-constraint="Center"/>
        <properties/>
        <border type="none"/>
        <children>
          <component id="b6117" class="javax.swing.JLabel" binding="lblUsuario">
            <constraints>
              <grid row="1" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="0" anchor="8" fill="0" indent="0" use-parent-layout="false"/>
              <gridbag weightx="0.0" weighty="0.0"/>
            </constraints>
            <properties>
              <text value="Usuario"/>
            </properties>
          </component>
          <component id="51469" class="javax.swing.JLabel" binding="lblPassword">
            <constraints>
              <grid row="2" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="0" anchor="8" fill="0" indent="0" use-parent-layout="false"/>
              <gridbag weightx="0.0" weighty="0.0"/>
            </constraints>
            <properties>
              <text value="Password"/>
            </properties>
          </component>
          <component id="70ca3" class="javax.swing.JTextField" binding="txtUsuario">
            <constraints>
              <grid row="1" column="2" row-span="1" col-span="1" vsize-policy="0" hsize-policy="6" anchor="8" fill="1" indent="0" use-parent-layout="false">
                <preferred-size width="150" height="-1"/>
              </grid>
              <gridbag weightx="0.0" weighty="0.0"/>
            </constraints>
            <properties>
              <preferredSize width="100" height="34"/>
            </properties>
          </component>
          <component id="49b5b" class="javax.swing.JTextField" binding="txtPassword">
            <constraints>
              <grid row="2" column="2" row-span="1" col-span="1" vsize-policy="0" hsize-policy="6" anchor="8" fill="1" indent="0" use-parent-layout="false">
                <preferred-size width="150" height="-1"/>
              </grid>
              <gridbag weightx="0.0" weighty="0.0"/>
            </constraints>
            <properties>
              <preferredSize width="100" height="34"/>
            </properties>
          </component>
          <vspacer id="34a02">
            <constraints>
              <grid row="0" column="1" row-span="1" col-span="1" vsize-policy="6" hsize-policy="1" anchor="0" fill="2" indent="0" use-parent-layout="false"/>
              <gridbag weightx="0.0" weighty="0.0"/>
